<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.steelpipe.content.mapper.AboutUsMapper">

    <resultMap id="BaseResultMap" type="com.steelpipe.content.entity.AboutUs">
        <id column="id" property="id"/>
        <result column="about_us" property="aboutUs"/>
        <result column="features" property="features"/>
        <result column="contact_phone" property="contactPhone"/>
        <result column="contact_email" property="contactEmail"/>
        <result column="contact_address" property="contactAddress"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM about_us ORDER BY id DESC
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM about_us WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.steelpipe.content.entity.AboutUs" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO about_us (about_us, features, contact_phone, contact_email, contact_address, create_time, update_time)
        VALUES (#{aboutUs}, #{features}, #{contactPhone}, #{contactEmail}, #{contactAddress}, NOW(), NOW())
    </insert>

    <update id="updateById" parameterType="com.steelpipe.content.entity.AboutUs">
        UPDATE about_us
        SET about_us = #{aboutUs},
            features = #{features},
            contact_phone = #{contactPhone},
            contact_email = #{contactEmail},
            contact_address = #{contactAddress},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM about_us WHERE id = #{id}
    </delete>

</mapper>