<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.steelpipe.content.mapper.ObtainInformationMapper">

    <insert id="insert">
        insert into `obtain_information` (time, title, content)
        values(#{time}, #{title}, #{content})
    </insert>

    <update id="updateById">
        update `obtain_information` set time = #{time}, title = #{title}, content = #{content}
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete from `obtain_information` where id = #{id}
    </delete>

    <delete id="deleteBatch">
        delete from `obtain_information` where id in
        <foreach collection="list" item="item" open="(" separator="," close=")">
            #{item.id}
        </foreach>
    </delete>

    <select id="selectAll" resultType="com.steelpipe.content.entity.ObtainInformation">
        select * from `obtain_information`
        <where>
            <if test="title != null and title != ''">
                AND MATCH(`title`, `content`) AGAINST(#{title} IN NATURAL LANGUAGE MODE)
            </if>
        </where>
    </select>

    <select id="selectById" resultType="com.steelpipe.content.entity.ObtainInformation">
        select * from `obtain_information`
        where id = #{id}
    </select>
</mapper>
